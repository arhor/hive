TZ=Europe/Warsaw
HOMEASSISTANT_IMAGE=ghcr.io/home-assistant/home-assistant:2026.5.3
ESPHOME_IMAGE=ghcr.io/esphome/esphome:2026.5.1

# Cat recognizer image built by the root Docker Compose stack.
CAT_RECOGNIZER_IMAGE=cat-recognizer:native

# Safe placeholder: replace with the ESP32-CAM snapshot endpoint in your private network.
# Keep real private IPs, tokens, credentials, and host-specific URLs in your uncommitted .env only.
CAT_RECOGNIZER_CAMERA_SNAPSHOT_URL=http://esp32-cam.local/snapshot

# Stub-only modes for the current skeleton: STUB, ALWAYS_PRESENT, or ALWAYS_ABSENT.
CAT_RECOGNIZER_DETECTION_MODE=STUB

# Keep the background worker off by default in the template to avoid polling a placeholder camera URL.
CAT_RECOGNIZER_WORKER_ENABLED=false

# Allows POST /api/recognition/run for manual local verification.
CAT_RECOGNIZER_DEBUG_MANUAL_TRIGGER_ENABLED=true
